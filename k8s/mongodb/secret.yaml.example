# MongoDB Secret – 실제 배포 전에 값을 변경하세요.
# 사용 방법:
#   1. 이 파일을 secret.yaml 로 복사: cp secret.yaml.example secret.yaml
#   2. 아래 base64 값을 실제 비밀번호로 교체
#      예: echo -n 'yourpassword' | base64
#   3. kubectl apply -f k8s/mongodb/secret.yaml
#
# ⚠️  secret.yaml 은 .gitignore 에 등록되어 있으며 버전 관리에 포함되지 않습니다.
# ⚠️  프로덕션 환경에서는 Sealed Secrets 또는 External Secrets Operator 사용을 권장합니다.
apiVersion: v1
kind: Secret
metadata:
  name: mongodb-secret
  namespace: stock-mldl
  labels:
    app.kubernetes.io/part-of: stock-mldl
type: Opaque
data:
  # echo -n 'root' | base64
  MONGO_ROOT_USERNAME: cm9vdA==
  # echo -n 'changeme' | base64  ← 반드시 변경
  MONGO_ROOT_PASSWORD: Y2hhbmdlbWU=
